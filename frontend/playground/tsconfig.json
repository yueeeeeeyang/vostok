{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@vostok/frontend": ["../packages/vostok.frontend/src/index.ts"],
      "@vostok/frontend/components": ["../packages/vostok.frontend/src/components/index.ts"],
      "@vostok/frontend/api": ["../packages/vostok.frontend/src/api/index.ts"],
      "@vostok/frontend/adapters": ["../packages/vostok.frontend/src/adapters/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
