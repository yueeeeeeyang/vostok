{
  "name": "frontend-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm --filter @vostok/frontend build && pnpm --filter playground build",
    "build:lib": "pnpm --filter @vostok/frontend build",
    "dev:playground": "pnpm --filter playground dev",
    "type-check": "pnpm -r type-check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
